    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "if (UV.x <= 0 || UV.x >= 1 || UV.y <= 0 || UV.y >= 1)\r\n{\r\n    \tColor = BaseColor;\n}\r\n\nfloat alpha = BaseColor.a;\r\nColor = float4(BaseColor.rgb, min(alpha, 1.0 - Texture.a));"
}

